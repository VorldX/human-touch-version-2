{
  "name": "vorldx-command-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-singleton.mjs",
    "realtime": "node realtime/server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:composio:unit": "node --test --experimental-strip-types tests/composio.service-core.test.ts",
    "test:composio:api": "node --test tests/composio.endpoints.smoke.test.mjs",
    "test:composio": "npm run test:composio:unit && npm run test:composio:api",
    "test:agent-run": "node --test --experimental-strip-types tests/agent.run.engine.test.ts tests/email-request-parser.test.ts",
    "test:agent-memory": "node --test --experimental-strip-types tests/agent.memory.scoring.test.ts tests/agent.memory.ranking.test.ts",
    "test:langgraph": "node --test --test-isolation=none --experimental-strip-types tests/langgraph.request-classifier.test.ts tests/langgraph.organization.graph.test.ts tests/langgraph.tool-execution-bridge.test.ts tests/langgraph.feature-gating.test.ts",
    "test:migration": "node --test --experimental-strip-types tests/migration.event-mapper.test.ts tests/agent.capability-guard.test.ts",
    "worker:queue-shadow": "node --experimental-strip-types workers/queue-shadow-worker.ts",
    "worker:outbox-dispatcher": "node --experimental-strip-types workers/outbox-dispatcher.ts",
    "pretypecheck": "node scripts/prisma-generate-safe.mjs",
    "prebuild": "prisma generate || npx prisma generate",
    "postinstall": "prisma generate || npx prisma generate",
    "prisma:generate": "prisma generate || npx prisma generate",
    "prisma:migrate": "prisma migrate dev || npx prisma migrate dev",
    "prisma:push": "prisma db push || npx prisma db push"
  },
  "dependencies": {
    "@composio/core": "^0.6.4",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "ajv": "^8.18.0",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "framer-motion": "^11.11.17",
    "inngest": "3.52.4",
    "lucide-react": "^0.462.0",
    "next": "^14.2.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-window": "^2.2.7",
    "reactflow": "^11.11.4",
    "redis": "^4.7.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.24",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
