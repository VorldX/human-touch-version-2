{
  "name": "vorldx-command-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-next.mjs && next dev",
    "realtime": "node realtime/server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:composio:unit": "node --test --experimental-strip-types tests/composio.service-core.test.ts",
    "test:composio:api": "node --test tests/composio.endpoints.smoke.test.mjs",
    "test:composio": "npm run test:composio:unit && npm run test:composio:api",
    "test:agent-run": "node --test --experimental-strip-types tests/agent.run.engine.test.ts",
    "pretypecheck": "node scripts/prisma-generate-safe.mjs",
    "prebuild": "prisma generate || npx prisma generate",
    "postinstall": "prisma generate || npx prisma generate",
    "prisma:generate": "prisma generate || npx prisma generate",
    "prisma:migrate": "prisma migrate dev || npx prisma migrate dev",
    "prisma:push": "prisma db push || npx prisma db push"
  },
  "dependencies": {
    "@composio/core": "0.6.3",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "framer-motion": "^11.11.17",
    "inngest": "3.52.4",
    "lucide-react": "^0.462.0",
    "next": "^14.2.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.24",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
